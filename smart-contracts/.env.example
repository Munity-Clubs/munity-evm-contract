# Deployer key. Use a dedicated deployer wallet, not a treasury/admin wallet.
# Both with and without 0x prefix are accepted.
PRIVATE_KEY=

# RPC providers
ALCHEMY_API_MAINNET=
ALCHEMY_API_SEPOLIA=
ALCHEMY_API_POLYGON=
ALCHEMY_API_AMOY=
ALCHEMY_API_BASE=
ALCHEMY_API_BASE_SEPOLIA=
ALCHEMY_API_OPT=
ALCHEMY_API_OPT_SEPOLIA=
ALCHEMY_API_ARB=
ALCHEMY_API_ARB_SEPOLIA=

# Block explorers
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=

# Optional: mainnet RPC for the local hardhat fork network.
FORK_URL=

# Optional: set to true for deploy scripts to verify after deployment.
VERIFY=false
VERIFY_CONFIRMATIONS=5
