# Deployer key. Use a dedicated deployer wallet, not a treasury/admin wallet.
# Both with and without 0x prefix are accepted.
PRIVATE_KEY=

# RPC providers
ALCHEMY_API_MAINNET=
ALCHEMY_API_SEPOLIA=
ALCHEMY_API_POLYGON=
ALCHEMY_API_AMOY=

# Block explorers
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# Optional: mainnet RPC for the local hardhat fork network.
FORK_URL=

# Optional: set to true for deploy scripts to verify after deployment.
VERIFY=false
VERIFY_CONFIRMATIONS=5
