# Deployer key — DO NOT PUT THE PRIVATE KEY HERE.
#
# .env is gitignored, but secrets on disk still leak via backups, shoulder-surfing,
# editor history, sync clients, etc. For Munity production deploys, load the
# private key into the shell session ONLY using:
#
#   source ./scripts/secure-key.sh
#
# That script reads the key interactively (no echo, no shell history), validates
# the derived address matches the expected deployer (0x30afF336…04ef), and exports
# PRIVATE_KEY into the current shell. Hardhat picks it up automatically.
# When the shell session ends, the key is gone — no disk footprint.
#
# For LOCAL DEV / TESTNET tinkering only (NOT production deploys), you may
# uncomment + populate the line below. Never commit a real key, even briefly.
#
# PRIVATE_KEY=

# RPC providers
ALCHEMY_API_MAINNET=
ALCHEMY_API_SEPOLIA=
ALCHEMY_API_POLYGON=
ALCHEMY_API_AMOY=
ALCHEMY_API_BASE=
ALCHEMY_API_BASE_SEPOLIA=
ALCHEMY_API_OPT=
ALCHEMY_API_OPT_SEPOLIA=
ALCHEMY_API_ARB=
ALCHEMY_API_ARB_SEPOLIA=

# Block explorer API keys
#
# A3 L2 chains (Base/Optimism/Arbitrum) verify via Blockscout — one API key
# value works across all 3 Blockscout instances. Get one at
# https://docs.blockscout.com/ (per-instance signup or shared key).
BLOCKSCOUT_API_KEY=

# Legacy chains (ETH + Polygon) — only needed if you ever deploy from this
# repo to those chains. A3 does not. Leave empty if unused.
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# Optional: mainnet RPC for the local hardhat fork network.
FORK_URL=

# Optional: set to true for deploy scripts to verify after deployment.
VERIFY=false
VERIFY_CONFIRMATIONS=5
